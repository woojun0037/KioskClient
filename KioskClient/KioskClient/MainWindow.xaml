<Window x:Class="KioskClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KioskClient"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="상품명"/>
            <TextBox Height="30"
                     Margin="0,5,0,10"
                     Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="가격"/>
            <TextBox Height="30"
                     Margin="0,5,0,10"
                     Text="{Binding ProductPrice, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="상품 불러오기"
                        Width="120"
                        Height="30"
                        Command="{Binding LoadProductCommand}"/>

                <Button Content="상품 추가"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Command="{Binding CreateProductCommand}"/>
                
                <Button Content="새 상품"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Command="{Binding NewProductCommand}"/>
                
                <Button Content="상품 수정"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Command="{Binding UpdateProductCommand}"/>

                <Button Content="상품 삭제"
                        Width="120"
                        Height="30"
                        Margin="10,0,0,0"
                        Command="{Binding DeleteProductCommand}"/>
            </StackPanel>

            <ListBox x:Name="ProductsListBox"
                     ItemsSource="{Binding Products}"
                     SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                     Margin="0,10,0,0"
                     Height="300"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10"
                                Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Id}" FontWeight="Bold"/>
                                <TextBlock Text=" - " />
                                <TextBlock Text="{Binding Name}" Margin="5,0,0,0"/>
                                <TextBlock Text=" - "/>
                                <TextBlock Text="{Binding Price}"/>
                                <TextBlock Text="원"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>